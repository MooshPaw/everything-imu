# Copy to keystore.properties (gitignored) to sign local release builds.
# storeFile is resolved relative to the mobile/ root.
#
# Generate the keystore once:
#   keytool -genkey -v -keystore release.keystore -alias eimu \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# CI reads the same values from env vars instead of this file:
#   ANDROID_RELEASE_KEYSTORE           -> storeFile (decoded path)
#   ANDROID_RELEASE_KEYSTORE_PASSWORD  -> storePassword
#   ANDROID_RELEASE_KEY_ALIAS          -> keyAlias
#   ANDROID_RELEASE_KEY_PASSWORD       -> keyPassword

storeFile=release.keystore
storePassword=changeme
keyAlias=eimu
keyPassword=changeme
